<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="menu_report" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="REPORT_DATE" class="java.lang.String"/>

    <queryString>
        <![CDATA[
            SELECT
                m.id,
                m.item_name,
                m.price,
                m.stock,
                m.status,
                COALESCE(SUM(o.quantity), 0) AS sold_today
            FROM menu m
            LEFT JOIN orders o ON m.item_name = o.item_name
            GROUP BY m.id
            ORDER BY m.item_name
        ]]>
    </queryString>

    <field name="id"         class="java.lang.Integer"/>
    <field name="item_name"  class="java.lang.String"/>
    <field name="price"      class="java.lang.Double"/>
    <field name="stock"      class="java.lang.Integer"/>
    <field name="status"     class="java.lang.String"/>
    <field name="sold_today" class="java.lang.Integer"/>

    <title>
        <band height="85">
            <staticText>
                <reportElement x="0" y="8" width="555" height="28"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[BIGTASK Restaurant — Menu Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="16"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <text><![CDATA[Item pricing, stock remaining, and units sold today]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="60" width="555" height="16"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Report Generated: " + $P{REPORT_DATE}]]>
                </textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="40" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="40" y="0" width="180" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Item Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="0" width="90" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Price (₱)]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="0" width="80" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Stock Left]]></text>
            </staticText>
            <staticText>
                <reportElement x="390" y="0" width="80" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Sold Today]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="0" width="85" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="40" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="0" width="180" height="20"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{item_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="220" y="0" width="90" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $F{price})]]>
                </textFieldExpression>
            </textField>
            <textField>
                <reportElement x="310" y="0" width="80" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{stock}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="390" y="0" width="80" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{sold_today}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="470" y="0" width="85" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>