<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="billing_report" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="CUSTOMER_NAME" class="java.lang.String"/>
    <parameter name="GRAND_TOTAL"   class="java.lang.Double"/>

    <queryString>
        <![CDATA[SELECT * FROM orders]]>
    </queryString>

    <field name="item_name" class="java.lang.String"/>
    <field name="quantity"  class="java.lang.Integer"/>
    <field name="total"     class="java.lang.Double"/>

    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="5" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[RECEIPT]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Bigtask Restaurant Management System]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="60" width="555" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression>
                    <![CDATA["Customer: " + $P{CUSTOMER_NAME}]]>
                </textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0"   y="0" width="280" height="25" backcolor="#FF9800" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[Item]]></text>
            </staticText>
            <staticText>
                <reportElement x="280" y="0" width="100" height="25" backcolor="#FF9800" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>	
                <text><![CDATA[Qty]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="175" height="25" backcolor="#FF9800" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[Amount]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0"   y="0" width="280" height="20"/>
                <textFieldExpression><![CDATA[$F{item_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="280" y="0" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="175" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="40">
            <line>
                <reportElement x="0" y="5" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="280" y="10" width="100" height="20"/>
                <textElement textAlignment="Center"><font isBold="true" size="12"/></textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="10" width="175" height="20"/>
                <textElement textAlignment="Center"><font isBold="true" size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{GRAND_TOTAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>