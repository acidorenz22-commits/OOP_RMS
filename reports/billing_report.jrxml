<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="billing_report" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="CUSTOMER_NAME"  class="java.lang.String"/>
    <parameter name="GRAND_TOTAL"    class="java.lang.Double"/>
    <parameter name="TOTAL_QTY"      class="java.lang.Integer"/>
    <parameter name="ORDER_REF"      class="java.lang.String"/>
    <parameter name="ORDER_TIME"     class="java.lang.String"/>
    <parameter name="AMOUNT_PAID"    class="java.lang.Double"/>
    <parameter name="CHANGE_AMOUNT"  class="java.lang.Double"/>

    <queryString>
        <![CDATA[SELECT * FROM orders WHERE order_ref = $P{ORDER_REF}]]>
    </queryString>

    <field name="item_name" class="java.lang.String"/>
    <field name="quantity"  class="java.lang.Integer"/>
    <field name="total"     class="java.lang.Double"/>

    <title>
        <band height="140">
            <staticText>
                <reportElement x="0" y="5" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[BIGTASK Restaurant]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="35" width="555" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11"/>
                </textElement>
                <text><![CDATA[Official Receipt]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="58" width="555" height="1"/>
            </line>
            <textField>
                <reportElement x="0" y="64" width="555" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Order Ref: " + $P{ORDER_REF}]]>
                </textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="84" width="555" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Date & Time: " + $P{ORDER_TIME}]]>
                </textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="104" width="555" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Customer: " + $P{CUSTOMER_NAME}]]>
                </textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="127" width="555" height="1"/>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="280" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Item]]></text>
            </staticText>
            <staticText>
                <reportElement x="280" y="0" width="100" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Qty]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="175" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Amount (₱)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="280" height="20"/>
                <textFieldExpression><![CDATA[$F{item_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="280" y="0" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="175" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $F{total})]]>
                </textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="120">
            <line>
                <reportElement x="0" y="5" width="555" height="1"/>
            </line>

            <!-- Total Items -->
            <staticText>
                <reportElement x="180" y="12" width="200" height="18"/>
                <textElement textAlignment="Right">
                    <font isBold="true" size="11"/>
                </textElement>
                <text><![CDATA[Total Items Ordered:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="12" width="175" height="18"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TOTAL_QTY}]]></textFieldExpression>
            </textField>

            <!-- Grand Total -->
            <staticText>
                <reportElement x="180" y="34" width="200" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true" size="13"/>
                </textElement>
                <text><![CDATA[GRAND TOTAL:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="34" width="175" height="20"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="13"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $P{GRAND_TOTAL})]]>
                </textFieldExpression>
            </textField>

            <!-- Amount Paid -->
            <staticText>
                <reportElement x="180" y="58" width="200" height="18"/>
                <textElement textAlignment="Right">
                    <font isBold="true" size="11"/>
                </textElement>
                <text><![CDATA[Amount Paid:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="58" width="175" height="18"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="11"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $P{AMOUNT_PAID})]]>
                </textFieldExpression>
            </textField>

            <!-- Change -->
            <staticText>
                <reportElement x="180" y="78" width="200" height="18"/>
                <textElement textAlignment="Right">
                    <font isBold="true" size="11"/>
                </textElement>
                <text><![CDATA[Change:]]></text>
            </staticText>
            <textField>
                <reportElement x="380" y="78" width="175" height="18"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="11"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $P{CHANGE_AMOUNT})]]>
                </textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="100" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="105" width="555" height="14"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <text><![CDATA[Thank you for dining with us! We hope to see you again.]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>