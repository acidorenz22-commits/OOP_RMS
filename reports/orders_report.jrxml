<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="orders_report" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="REPORT_DATE" class="java.lang.String"/>

    <queryString>
        <![CDATA[
            SELECT
                order_ref,
                order_time,
                item_name,
                quantity,
                total,
                amount_paid,
                change_amount
            FROM orders
            ORDER BY order_ref, id
        ]]>
    </queryString>

    <field name="order_ref"     class="java.lang.String"/>
    <field name="order_time"    class="java.lang.String"/>
    <field name="item_name"     class="java.lang.String"/>
    <field name="quantity"      class="java.lang.Integer"/>
    <field name="total"         class="java.lang.Double"/>
    <field name="amount_paid"   class="java.lang.Double"/>
    <field name="change_amount" class="java.lang.Double"/>

    <variable name="GRAND_REVENUE" class="java.lang.Double"
        calculation="Sum">
        <variableExpression><![CDATA[$F{total}]]></variableExpression>
    </variable>

    <variable name="TOTAL_SOLD" class="java.lang.Integer"
        calculation="Sum">
        <variableExpression><![CDATA[$F{quantity}]]></variableExpression>
    </variable>

    <title>
        <band height="85">
            <staticText>
                <reportElement x="0" y="8" width="555" height="28"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[BIGTASK Restaurant — Orders Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="16"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <text><![CDATA[All customer orders, quantities sold, and total revenue for today]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="60" width="555" height="16"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Report Generated: " + $P{REPORT_DATE}]]>
                </textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="110" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Order Ref]]></text>
            </staticText>
            <staticText>
                <reportElement x="110" y="0" width="100" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Date & Time]]></text>
            </staticText>
            <staticText>
                <reportElement x="210" y="0" width="110" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Item]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="0" width="45" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Qty]]></text>
            </staticText>
            <staticText>
                <reportElement x="365" y="0" width="65" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Amount (₱)]]></text>
            </staticText>
            <staticText>
                <reportElement x="430" y="0" width="62" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Paid (₱)]]></text>
            </staticText>
            <staticText>
                <reportElement x="492" y="0" width="63" height="25"
                    backcolor="#1B4332" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="8"/>
                </textElement>
                <text><![CDATA[Change (₱)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="110" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{order_ref}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="110" y="0" width="100" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{order_time}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="210" y="0" width="110" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{item_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="320" y="0" width="45" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="365" y="0" width="65" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $F{total})]]>
                </textFieldExpression>
            </textField>
            <textField>
                <reportElement x="430" y="0" width="62" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $F{amount_paid})]]>
                </textFieldExpression>
            </textField>
            <textField>
                <reportElement x="492" y="0" width="63" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $F{change_amount})]]>
                </textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="60">
            <line>
                <reportElement x="0" y="5" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="280" y="12" width="140" height="18"/>
                <textElement textAlignment="Right">
                    <font isBold="true" size="11"/>
                </textElement>
                <text><![CDATA[Total Units Sold:]]></text>
            </staticText>
            <textField>
                <reportElement x="420" y="12" width="135" height="18"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_SOLD}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="280" y="34" width="140" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true" size="13"/>
                </textElement>
                <text><![CDATA[TOTAL REVENUE:]]></text>
            </staticText>
            <textField>
                <reportElement x="420" y="34" width="135" height="20"/>
                <textElement textAlignment="Center">
                    <font isBold="true" size="13"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["₱" + String.format("%.2f", $V{GRAND_REVENUE})]]>
                </textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>