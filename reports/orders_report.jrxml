<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="orders_report" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <queryString>
        <![CDATA[SELECT * FROM orders]]>
    </queryString>

    <field name="id"        class="java.lang.Integer"/>
    <field name="item_name" class="java.lang.String"/>
    <field name="quantity"  class="java.lang.Integer"/>
    <field name="total"     class="java.lang.Double"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Orders Report]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0"   y="0" width="60"  height="25" backcolor="#2196F3" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="60"  y="0" width="250" height="25" backcolor="#2196F3" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[Item Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="0" width="100" height="25" backcolor="#2196F3" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[Quantity]]></text>
            </staticText>
            <staticText>
                <reportElement x="410" y="0" width="145" height="25" backcolor="#2196F3" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[Total]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0"   y="0" width="60"  height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60"  y="0" width="250" height="20"/>
                <textFieldExpression><![CDATA[$F{item_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="310" y="0" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="410" y="0" width="145" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="30">
            <staticText>
                <reportElement x="310" y="5" width="100" height="20"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[GRAND TOTAL:]]></text>
            </staticText>
            <textField>
                <reportElement x="410" y="5" width="145" height="20"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>